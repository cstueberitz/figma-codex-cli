#!/bin/bash

# fig-start — Launch Figma CLI + Codex
# Connects to Figma, lets you pick an open file, then launches Codex.
#
# Usage:
#   fig-start          → Yolo Mode (default) with file selector
#   fig-start --safe   → Safe Mode (plugin-based, no patching)
#   fig-start --here   → Stay in current directory (don't cd to repo)
#   fig-start --setup  → set/change the figma-codex-cli repo path

CONFIG_DIR="$HOME/.figma-codex-cli"
CONFIG_FILE="$CONFIG_DIR/config.json"
LEGACY_CONFIG_FILE="$HOME/.figma-cli/config.json"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Config helpers ──

get_daemon_token() {
    local token_file="$HOME/.figma-ds-cli/.daemon-token"
    if [ -f "$token_file" ]; then
        cat "$token_file" 2>/dev/null
    fi
}

get_repo_path() {
    if [ -f "$CONFIG_FILE" ]; then
        python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('repoPath',''))" 2>/dev/null
        return
    fi

    if [ -f "$LEGACY_CONFIG_FILE" ]; then
        local repo_path
        repo_path=$(python3 -c "import json; print(json.load(open('$LEGACY_CONFIG_FILE')).get('repoPath',''))" 2>/dev/null)
        if [ -n "$repo_path" ]; then
            save_repo_path "$repo_path"
            printf '%s' "$repo_path"
        fi
    fi
}

is_valid_repo() {
    local repo_path="$1"
    [ -f "$repo_path/src/index.js" ] && [ -f "$repo_path/AGENTS.md" ]
}

save_repo_path() {
    mkdir -p "$CONFIG_DIR"
    python3 -c "
import json, os
path = '$CONFIG_FILE'
cfg = {}
if os.path.exists(path):
    with open(path) as f: cfg = json.load(f)
cfg['repoPath'] = '$1'
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
"
}

launch_codex() {
    if ! command -v codex > /dev/null 2>&1; then
        echo -e "  ${RED}Codex CLI not found in PATH.${NC}"
        echo -e "  Install or expose ${BOLD}codex${NC}, then run ${BOLD}fig-start${NC} again."
        exit 1
    fi

    if [ "$STAY_HERE" = false ]; then
        exec codex -C "$REPO_PATH"
    fi

    exec codex -C "$CURRENT_DIR" --add-dir "$REPO_PATH" "Before doing anything else, read and follow $REPO_PATH/AGENTS.md. The figma-codex-cli repo lives at $REPO_PATH. Use that repo for figma CLI commands while keeping the current directory context."
}

require_cmd() {
    local cmd="$1"
    local install_hint="$2"

    if command -v "$cmd" > /dev/null 2>&1; then
        return
    fi

    echo -e "  ${RED}Missing required command:${NC} ${BOLD}$cmd${NC}"
    if [ -n "$install_hint" ]; then
        echo -e "  ${YELLOW}$install_hint${NC}"
    fi
    exit 1
}

# ── Arrow-key selector (same UX as fancoolo-start) ──

select_file() {
    local options=("$@")
    local count=${#options[@]}
    local selected=0

    tput civis > /dev/tty 2>/dev/null
    trap 'tput cnorm > /dev/tty 2>/dev/null' EXIT

    draw_menu() {
        if [ "$1" = "redraw" ]; then
            printf "\033[%dA" "$((count + 2))" > /dev/tty
        fi

        printf "${BOLD}Select a Figma file (↑↓ arrows, Enter to confirm):${NC}\n" > /dev/tty
        printf "\n" > /dev/tty
        for i in "${!options[@]}"; do
            if [ "$i" -eq "$selected" ]; then
                printf "  ${GREEN}▸ %s${NC}\n" "${options[$i]}" > /dev/tty
            else
                printf "    %s\n" "${options[$i]}" > /dev/tty
            fi
        done
    }

    draw_menu "first"

    while true; do
        IFS= read -rsn1 key < /dev/tty

        case "$key" in
            $'\x1b')
                read -rsn2 seq < /dev/tty
                case "$seq" in
                    '[A')
                        ((selected--))
                        [ "$selected" -lt 0 ] && selected=$((count - 1))
                        ;;
                    '[B')
                        ((selected++))
                        [ "$selected" -ge "$count" ] && selected=0
                        ;;
                esac
                ;;
            ''|$'\n'|$'\r')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                printf '%s' "${options[$selected]}"
                return
                ;;
            'q')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                return
                ;;
        esac

        draw_menu "redraw"
    done
}

# ── Main ──

# Handle flags
SAFE_MODE=false
STAY_HERE=false
SETUP_MODE=false
CURRENT_DIR="$(pwd)"

for arg in "$@"; do
    case "$arg" in
        --safe) SAFE_MODE=true ;;
        --here) STAY_HERE=true ;;
        --setup) SETUP_MODE=true ;;
    esac
done

require_cmd python3 "Install Python 3 so fig-start can store and read its config."

if [ "$SETUP_MODE" = false ]; then
    require_cmd curl "Install curl so fig-start can probe the local Figma debug endpoints."
    require_cmd node "Install Node.js 18+ so fig-start can run the figma CLI."
fi

if [ "$SETUP_MODE" = true ]; then
    printf "${BOLD}Enter the path to your figma-codex-cli repo:${NC} "
    read -r repo_path < /dev/tty
    repo_path="${repo_path/#\~/$HOME}"
    if ! is_valid_repo "$repo_path"; then
        echo -e "${RED}Not a valid figma-codex-cli repo:${NC} $repo_path"
        exit 1
    fi
    save_repo_path "$repo_path"
    echo -e "${GREEN}Saved.${NC} Run ${BOLD}fig-start${NC} to begin."
    exit 0
fi

# Resolve repo path
REPO_PATH=$(get_repo_path)

if [ -z "$REPO_PATH" ] || [ ! -d "$REPO_PATH" ]; then
    # Try to find it relative to this script
    SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
    if is_valid_repo "$SCRIPT_DIR"; then
        REPO_PATH="$SCRIPT_DIR"
        save_repo_path "$REPO_PATH"
    else
        echo -e "${YELLOW}figma-codex-cli repo not configured.${NC}"
        printf "${BOLD}Enter the path to your figma-codex-cli repo:${NC} "
        read -r REPO_PATH < /dev/tty
        REPO_PATH="${REPO_PATH/#\~/$HOME}"
        if ! is_valid_repo "$REPO_PATH"; then
            echo -e "${RED}Not a valid figma-codex-cli repo:${NC} $REPO_PATH"
            exit 1
        fi
        save_repo_path "$REPO_PATH"
    fi
fi

if ! is_valid_repo "$REPO_PATH"; then
    echo -e "${RED}Configured repo is missing required files:${NC} $REPO_PATH"
    echo -e "  Expected ${BOLD}src/index.js${NC} and ${BOLD}AGENTS.md${NC}"
    echo -e "  Run ${BOLD}fig-start --setup${NC} to point to a valid checkout."
    exit 1
fi

CLI="$REPO_PATH/src/index.js"

echo ""
if [ "$SAFE_MODE" = true ]; then
    echo -e "${BOLD}  fig-start${NC} ${DIM}- Figma CLI launcher for Codex (Safe Mode)${NC}"
else
    echo -e "${BOLD}  fig-start${NC} ${DIM}- Figma CLI launcher for Codex${NC}"
fi
echo ""

# Step 1: Check if Figma is running, start if not
if ! pgrep -x "Figma" > /dev/null 2>&1; then
    echo -e "  ${YELLOW}Starting Figma...${NC}"
    open -a Figma
    sleep 3
fi

# Step 2: Connect to Figma
if [ "$SAFE_MODE" = true ]; then
    # ── Safe Mode: plugin-based connection ──
    # Run connect --safe interactively so user sees plugin setup instructions
    echo -e "  ${BOLD}🔒 Safe Mode${NC} — plugin-based, no patching required"
    echo ""
    node "$CLI" connect --safe
    if [ $? -ne 0 ]; then
        echo -e "  ${RED}Connection failed.${NC}"
        exit 1
    fi
    echo ""

    # Skip file selector (Safe Mode only sees the active file via plugin)
    echo -e "  ${GREEN}Launching Codex...${NC}"
    echo ""
    launch_codex
else
    # ── Yolo Mode: CDP-based connection ──
    # Check if CDP is already accessible (avoid killing/restarting Figma)
    CDP_OK=false
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:9222/json 2>/dev/null | grep -q "200"; then
        CDP_OK=true
    fi

    if [ "$CDP_OK" = true ]; then
        # Figma is already accessible — just ensure daemon is running
        DAEMON_OK=false
        DAEMON_TOKEN=$(get_daemon_token)
        if [ -n "$DAEMON_TOKEN" ]; then
            if curl -s -o /dev/null -w "%{http_code}" -H "X-Daemon-Token: $DAEMON_TOKEN" http://localhost:3456/health 2>/dev/null | grep -q "200"; then
                DAEMON_OK=true
            fi
        fi
        if [ "$DAEMON_OK" = false ]; then
            echo -e "  Starting daemon..."
            node "$CLI" daemon restart > /dev/null 2>&1
            sleep 1
        fi
        echo -e "  ${GREEN}✓ Connected${NC}"
    else
        # Not accessible — run full connect (will kill + restart Figma)
        echo -e "  Connecting to Figma..."
        CONNECT_OUT=$(node "$CLI" connect 2>&1)
        if [ $? -ne 0 ]; then
            echo -e "  ${RED}Connection failed:${NC}"
            echo "$CONNECT_OUT"
            echo ""
            echo -e "  ${YELLOW}Tip:${NC} Try ${BOLD}fig-start --safe${NC} if patching fails."
            exit 1
        fi
        echo -e "  ${GREEN}✓ Connected${NC}"
        # Wait for Figma to fully restore all tabs after restart
        sleep 3
    fi

    # Step 3: List open files and let user pick
    echo -e "  Loading open files..."
    FILES_JSON=$(node "$CLI" files 2>/dev/null)

    if [ -z "$FILES_JSON" ] || echo "$FILES_JSON" | grep -q '"error"'; then
        echo -e "  ${RED}Could not list files.${NC} Is Figma open with a file?"
        exit 1
    fi

    # Parse file titles
    FILE_TITLES=()
    while IFS= read -r title; do
        FILE_TITLES+=("$title")
    done < <(echo "$FILES_JSON" | python3 -c "
import json, sys
files = json.load(sys.stdin)
for f in files:
    t = f.get('title', 'Untitled')
    # Clean up Figma title format (remove ' – Figma' suffix)
    t = t.replace(' – Figma', '').replace(' - Figma', '')
    print(t)
" 2>/dev/null)

    if [ ${#FILE_TITLES[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}No Figma files detected.${NC} Open a file in Figma first."
        echo ""
        echo -e "  Launching Codex anyway..."
        echo ""
        launch_codex
    fi

    SELECTED_TITLE=""

    echo ""
    SELECTED_TITLE=$(select_file "${FILE_TITLES[@]}")
    if [ -z "$SELECTED_TITLE" ]; then
        echo "  Cancelled."
        exit 0
    fi

    echo -e "  ${GREEN}✓ File: ${BOLD}${SELECTED_TITLE}${NC}"
    echo ""

    # Step 4: Launch Codex
    echo -e "  ${GREEN}Launching Codex...${NC}"
    echo ""
    launch_codex
fi
